# GEMINI_API_KEY: Required for the Vercel serverless chat function.
# Set this in Vercel Project Settings -> Environment Variables.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# WEB3FORMS_KEY: Optional key for the contact form submission service.
# If omitted, the contact form simulates a successful send in local/dev.
WEB3FORMS_KEY="MY_WEB3FORMS_KEY"

# APP_URL: Optional public app URL.
APP_URL="MY_APP_URL"
